# Next.js production env (non-secret placeholders only)
# Slot mapping: Next #1 -> revindennis.cloud -> PORT 3000

NODE_ENV=production
PORT=3000

# Server-side mail config (used by /api/contact)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_app_password
CONTACT_TO_EMAIL=owner@example.com
# Optional; default falls back to SMTP_USER
CONTACT_FROM_EMAIL=no-reply@revindennis.cloud

# Jika nanti ada browser-side call ke API portfolio, gunakan NEXT_PUBLIC_* dan isi HTTPS URL:
# NEXT_PUBLIC_POS_API_URL=https://pos-api.revindennis.cloud
# NEXT_PUBLIC_FUTSAL_API_URL=https://futsal-api.revindennis.cloud
# NEXT_PUBLIC_SIM_API_URL=https://sim-api.revindennis.cloud
