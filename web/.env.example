### Frontend (Vite)
# Point the frontend to your API base URL if not using Vite proxy.
# VITE_API_BASE_URL=http://localhost:8787

### Contact API server
API_PORT=8787

### Gmail / Google Workspace SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password

### Contact mail routing
# Where contact form submissions should arrive (an email you own).
CONTACT_TO_EMAIL=your_inbox@example.com

# Optional: override the From header (defaults to SMTP_USER)
# CONTACT_FROM_EMAIL=your_email@gmail.com

